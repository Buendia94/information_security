  "audit_trigger_urls": [
    "http://10.10.60.56:8080/api/admin/users",
    "http://10.10.60.56:8080/login"
  ],
  "firmware_files": [
    "/home/buendia94/code/information/gbt45502_tester_project/samples/firmware.bin"
  ],
  "app_packages": [
    "/home/buendia94/code/information/gbt45502_tester_project/samples/robot_app.zip"
  ],
  "log_dirs": [
    "/var/log",
    "/home/cao/.ros/log",
    "/opt/cao/logs"
  ],
  "storage_protection_paths": [
    "/boot",
    "/etc",
    "/opt/robot"
  ],
  "secure_boot_check_command": "mokutil --sb-state",
  "update_check_command": "cat /etc/os-release && uname -a",
  "rollback_check_command": "lsblk",
  "software_inventory": [
    {
      "name": "Ubuntu",
      "version": "22.04",
      "nvd_keyword": "Ubuntu 22.04"
    },
    {
      "name": "OpenSSH",
      "version": "8.9",
      "nvd_keyword": "OpenSSH 8.9"
    },
    {
      "name": "nginx",
      "version": "1.18.0",
      "nvd_keyword": "nginx 1.18.0"
    }
  ],
  "nmap": {
    "path": "nmap",
    "args": "-sV --script vuln",
    "ports": "1-10000",
    "timeout_sec": 600,
    "max_targets": 20
  },
  "vulnerability_lookup": {
    "enable_nvd": true,
    "nvd_api_key": "",
    "nvd_max_results_per_item": 10,
    "nvd_delay_sec": 6.5,
    "enable_osv": true,
    "osv_packages": [
      {
        "name": "requests",
        "version": "2.31.0",
        "ecosystem": "PyPI"
      }
    ],
    "enable_pip_audit": true,
    "pip_audit_command": "python -m pip_audit -f json"
  },
  "threat_detection": {
    "allow_create_eicar": true,
    "scanner_command": "clamscan {file}",
    "eicar_filename": "eicar_test_file.com",
    "timeout_sec": 120,
    "cleanup": true
  }
}